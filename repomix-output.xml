 * @deprecated Không dùng nữa — system prompt do LM Studio quản lý.
 * Giữ lại để không break nếu có file import cũ.
 */
export function buildSystemPrompt(ragResult: RAGResult): string {
  return formatRAGContext(ragResult);
}
